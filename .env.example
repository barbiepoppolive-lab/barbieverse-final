# ============================================
# Barbieverse Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Supabase (Required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@host:5432/postgres

# --- Admin (Required) ---
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_SESSION_SECRET=at-least-32-characters-long-secret

# --- App URL ---
PUBLIC_APP_URL=https://your-domain.com

# --- Telegram Bot (Admin Alerts — Free) ---
# Create bot: @BotFather on Telegram → /newbot → copy token
# Get chat ID: send a message to your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- WhatsApp (Manual — No API needed) ---
# WhatsApp messages are sent manually by admin via one-click buttons in admin panel
# No Facebook/Meta account needed!

# --- Optional: Email (Brevo) ---
# BREVO_API_KEY=your-brevo-key

# --- Free AI APIs (No Credit Card Required) ---
# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (fastest free inference): https://console.groq.com/keys
GROQ_API_KEY=

# Mistral (best code model): https://console.mistral.ai/keys
MISTRAL_API_KEY=

# Cerebras (highest throughput): https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# --- Local AI (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic (UGC Validation) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- OpenRouter (Multi-Model API) ---
# One API key for Claude, GPT-4, Gemini, Llama, Mistral, Qwen, and more
# Sign up: https://openrouter.ai — Free tier available
# Pay-per-use pricing, no monthly commitment
OPENROUTER_API_KEY=

# --- xAI (Grok) ---
# High-quality reasoning and code model
# Sign up: https://console.x.ai — Free tier available
XAI_API_KEY=

# --- Video Generation (fal.ai) ---
# One API key for Kling video + ElevenLabs voice + 1000+ AI models
# Sign up: https://fal.ai — Pay-per-use, no subscription needed
# Cost: ~$0.21-0.35 per 5-second video clip, ~$0.05 per 1K voice characters
FAL_KEY=

# --- Cron Automation ---
# Secret for /api/public/cron-scrape endpoint (set this to a random string)
CRON_SECRET=your-cron-secret-here

# --- Scraping Services (Paid) ---
# Phantombuster (Instagram deep scraping): https://phantombuster.com
# Plans: Starter $69/mo — 100 profile scrapes/day
PHANTOMBUSTER_API_KEY=

# Apify (Multi-platform scraping): https://apify.com
# Free tier: $5/mo credits — Instagram, Facebook, Twitter, YouTube, Telegram
APIFY_TOKEN=

# --- Social Media Monitoring (Free APIs) ---
# Twitter/X: https://developer.x.com — Free tier: 1,500 reads/month
TWITTER_BEARER_TOKEN=

# Reddit: No token needed (uses User-Agent auth)
# YouTube: https://console.cloud.google.com — Free: 10,000 units/day
YOUTUBE_API_KEY=
# Facebook: Uses Apify (already configured above)

# --- Dev Only ---
# DB_SSL_INSECURE=true
